# Copy to .env and fill in. Never commit real keys.
JWT_SECRET=change-me

# OCR: leave as mock to run with no AWS account.
# Set to "textract" and provide AWS creds (env or task role) for real ID scanning.
OCR_PROVIDER=mock
AWS_REGION=us-east-1

# Stripe TEST mode only (starts with sk_test_). Leave blank to mock payments.
STRIPE_SECRET_KEY=
